generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONTACTED
  CONFIRMED
  FULFILLED
  CANCELLED
}

enum CustomerType {
  NORMAL
  WHOLESALE
}

enum LogoType {
  TEXT
  IMAGE
}

model Review {
  id           String   @id @default(cuid())
  customerName String
  content      String
  rating       Int
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model StoreSettings {
  id                  String   @id @default("default")
  logoType            LogoType @default(TEXT)
  logoText            String   @default("Marwa\nCrystal")
  logoImageUrl        String?
  logoColor           String   @default("#c9a227")
  logoSize            String   @default("2xl")
  logoFontWeight      String   @default("900")
  logoWidth           Int      @default(160)
  logoHeight          Int      @default(48)
  footerLogoWidth     Int      @default(180)
  footerLogoHeight    Int      @default(56)
  footerDescription   String
  socialUrls          Json
  contactInfo         Json
  copyrightText       String
  announcementText    String
  announcementEnabled Boolean  @default(true)
  announcementStyle   Json
  updatedAt           DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id        String       @id @default(cuid())
  name      String
  phone     String       @unique
  email     String?
  city      String
  address   String?
  type      CustomerType @default(NORMAL)
  orders    Order[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([phone])
}

model Collection {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  description    String
  heroImageUrl   String?
  imageAlt       String?
  seoTitle       String?
  seoDescription String?
  isFeatured     Boolean   @default(false)
  isVisible      Boolean   @default(true)
  sortOrder      Int       @default(0)
  products       Product[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([isVisible, sortOrder])
}

model Product {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String
  details         String?
  price           Int
  discountPrice   Int?
  wholesalePrice  Int?
  wholesaleMinQty Int?
  stock           Int             @default(0)
  sku             String?         @unique
  badge           String?
  status          ProductStatus   @default(DRAFT)
  isFeatured      Boolean         @default(false)
  seoTitle        String?
  seoDescription  String?
  collectionId    String
  collection      Collection      @relation(fields: [collectionId], references: [id], onDelete: Restrict)
  images          ProductImage[]
  orderItems      OrderItem[]
  stockMovements  StockMovement[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([collectionId])
  @@index([status])
}

model ProductImage {
  id                 String   @id @default(cuid())
  productId          String
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url                String
  alt                String?
  cloudinaryPublicId String?
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())

  @@index([productId])
}

model Order {
  id            String       @id @default(cuid())
  orderNumber   String       @unique
  status        OrderStatus  @default(PENDING)
  customerType  CustomerType @default(NORMAL)
  subtotal      Int
  total         Int
  note          String?
  whatsappText  String
  customerId    String
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items         OrderItem[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([customerId])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName     String
  productSlug     String
  quantity        Int
  unitPrice       Int
  lineTotal       Int
  isWholesale     Boolean @default(false)
}

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  reason    String
  createdAt DateTime @default(now())

  @@index([productId])
}
