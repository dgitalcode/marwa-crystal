# Database (PostgreSQL — Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/marwa_crystal?schema=public"

# Auth.js / NextAuth (admin panel)
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"

# Seeded admin (used by `npm run db:seed` only — change password after first login)
ADMIN_EMAIL="admin@marwacrystal.local"
ADMIN_PASSWORD="change-this-password"

# Storefront
NEXT_PUBLIC_STORE_NAME="Marwa Crystal"
NEXT_PUBLIC_STORE_URL="https://your-domain.vercel.app"

# WhatsApp (digits only, no + or spaces) — production: 212704460891
NEXT_PUBLIC_WHATSAPP_PHONE="212704460891"

# Contact email (fallback before admin settings are configured)
NEXT_PUBLIC_CONTACT_EMAIL="marwacrystal1@gmail.com"

# Cloudinary (server-side uploads — never commit real values)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional: client-side Cloudinary widget (if used later)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
